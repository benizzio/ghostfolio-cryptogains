        enum scope_reliability
        ActivityRecord_array activities
        ProtectedSnapshot protected_snapshot
        ReportRequest_array report_requests
        CapitalGainsReport_array capital_gains_reports
    }

    ActivityRecord {
        string source_id
        RFC3339_timestamp_string occurred_at
        enum activity_type
        string asset_identity_key
        string asset_symbol
        string_nullable asset_name
