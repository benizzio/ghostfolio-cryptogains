        ReportRequest report_request
        ProtectedActivityCache protected_activity_cache
        ReportDocument_nullable report_document
    }

    ReportDocumentType {
        enum markdown
        ReportDocument_array report_documents
    }

    ReportDocument {
        ReportDocumentType document_type
        string content
        integer year
        enum cost_basis_method
        timestamp generated_at
        CapitalGainsReport capital_gains_report
        ReportOutputFile_nullable report_output_file
    }

    ReportOutputFile {
        path documents_directory
        string filename
        path path
        timestamp saved_at
        boolean open_requested
        string_nullable open_error
        ReportDocument report_document
        ReportGenerationOutcome report_generation_outcome
    }

    ReportFailureDiagnostics {
        boolean eligible
        enum status
        enum_nullable failure_category
        path_nullable artifact_path
        string_nullable generation_message
        ActivityRecord_nullable offending_activity_record
        enum_nullable redaction_mode
        ReportGenerationOutcome report_generation_outcome
    }

    ReportGenerationOutcome {
        boolean success
        path_nullable saved_path
        boolean open_failed
        string message
        enum_nullable failure_category
        ReportFailureDiagnostics_nullable diagnostics
        SyncAndReportsContext sync_and_reports_context
        ReportOutputFile_nullable report_output_file
    }

