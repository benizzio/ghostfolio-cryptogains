        string_nullable order_currency
        decimal_nullable order_unit_price
        decimal_nullable order_gross_value
        decimal_nullable order_fee_amount
        string_nullable asset_profile_currency
        decimal_nullable asset_profile_unit_price
        decimal_nullable asset_profile_fee_amount
        string_nullable base_currency
        decimal_nullable base_gross_value
        decimal_nullable base_fee_amount
        string_nullable comment
        SourceScope_nullable source_scope
        string raw_hash
        ProtectedActivityCache protected_activity_cache
        ActivityCalculationInput_nullable activity_calculation_input
    }

    SourceScope {
        string scope_id
        string_nullable scope_name
        enum scope_kind
        enum reliability
        ActivityRecord_array activity_records
        ActivityCalculationInput_array activity_calculation_inputs
        ApplicableScope_array applicable_scopes
    }

